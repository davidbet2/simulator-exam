rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Questions: anyone can read (exam), only admins can write
    match /questions/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Settings: anyone can read (exam uses them), only admins can write
    match /settings/{certId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Certifications: anyone can read (public simulator), only admins can write
    match /certifications/{certId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Admins: a user can read their own admin doc to check status.
    // Existing admins can list and read all admin docs (for the admin panel).
    // Only existing admins can write (add or remove admin docs).
    match /admins/{adminEmail} {
      allow read: if request.auth != null
        && (request.auth.token.email == adminEmail
            || exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Users: each user reads and writes only their own profile document.
    // Admins can read, list, and update (plan changes, ban) any user profile.
    match /users/{uid} {
      allow read, list: if request.auth != null
        && (request.auth.uid == uid
            || exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
      // On create, owners cannot seed themselves into any privileged tier.
      allow create: if request.auth != null && request.auth.uid == uid
        && (!('plan' in request.resource.data) || request.resource.data.plan == 'free')
        && !request.resource.data.keys().hasAny(['isPro','role','verifiedAuthor','reputationScore','banned']);
      allow update: if request.auth != null && (
        // Admins can update any user (plan, banned, notes, etc.)
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
        // Owners cannot change any privileged field.
        || (request.auth.uid == uid
            && !request.resource.data.diff(resource.data).affectedKeys()
                  .hasAny(['plan','isPro','role','verifiedAuthor','reputationScore','banned']))
      );
    }

    // Attempts: users can read and create their own attempts; admins can list/read all. No updates or deletes.
    match /attempts/{attemptId} {
      allow read, list: if request.auth != null
        && (resource.data.uid == request.auth.uid
            || exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // Audit log: append-only. Only admins can read or list. Only admins can create.
    // No update/delete ever — tamper-evident.
    match /auditLog/{logId} {
      allow read, list: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
        && request.resource.data.actorEmail == request.auth.token.email;
    }

    // Feature flags: public read (app reads them to toggle features), admin-only write.
    match /featureFlags/{flagId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // ExamSets: PUBLISHED sets are publicly readable (SEO-indexable, no auth required).
    // Unpublished/draft sets are only readable by owner or admins.
    // Only the owner can create/update/delete their set.
    match /examSets/{setId} {
      allow get: if resource.data.published == true
        || (request.auth != null
            && (resource.data.ownerUid == request.auth.uid
                || exists(/databases/$(database)/documents/admins/$(request.auth.token.email))));
      // Listing: admins may list freely. For everyone else, the rule is
      // evaluated per-document; clients MUST filter by published==true (and
      // bound the limit), otherwise any non-published doc trips the rule and
      // the entire query is rejected. This prevents enumeration of drafts.
      // NOTE: request.query.filters does NOT exist in Firestore Rules — only
      // limit/offset/orderBy are exposed. Use resource.data instead.
      allow list: if
        (request.auth != null
          && exists(/databases/$(database)/documents/admins/$(request.auth.token.email)))
        || (request.query.limit <= 100
            && resource.data.published == true);
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.questionCount is int
        && request.resource.data.questionCount >= 1
        && request.resource.data.questionCount <= 500
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && (!('official' in request.resource.data) || request.resource.data.official == false);
      // Update: owner/admin for full write. Authenticated non-owners may
      // only touch aggregate counter fields (rating/favorites) — enabling
      // client-side denormalization when a user rates or favorites a set.
      allow update: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid
        || exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['ratingSum','ratingCount','ratingAvg','wilsonScore','favoritesCount','updatedAt'])
          && request.resource.data.ratingSum is number
          && request.resource.data.ratingCount is int
          && request.resource.data.ratingCount >= 0
          && request.resource.data.ratingAvg is number
          && request.resource.data.ratingAvg >= 0
          && request.resource.data.ratingAvg <= 5
          && request.resource.data.wilsonScore is number
          && request.resource.data.wilsonScore >= 0
          && request.resource.data.wilsonScore <= 1
          && request.resource.data.favoritesCount is int
          && request.resource.data.favoritesCount >= 0
        )
      );
      allow delete: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid
            || exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));

      // Questions of a published set are public (SEO + preview).
      // For unpublished sets, only owner/admins can read.
      match /questions/{qId} {
        allow read: if
          get(/databases/$(database)/documents/examSets/$(setId)).data.published == true
          || (request.auth != null
              && (get(/databases/$(database)/documents/examSets/$(setId)).data.ownerUid == request.auth.uid
                  || exists(/databases/$(database)/documents/admins/$(request.auth.token.email))));
        allow write: if request.auth != null
          && (get(/databases/$(database)/documents/examSets/$(setId)).data.ownerUid == request.auth.uid
              || exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
      }

      // Ratings: one per user per set (doc id = uid prevents duplicates).
      // Public read. A set's author CANNOT rate their own set.
      match /ratings/{uid} {
        allow read, list: if true;
        allow create, update: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.uid == uid
          && request.resource.data.stars is number
          && request.resource.data.stars >= 1
          && request.resource.data.stars <= 5
          && get(/databases/$(database)/documents/examSets/$(setId)).data.ownerUid != uid;
        allow delete: if request.auth != null
          && (request.auth.uid == uid
              || exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
      }
    }

    // Favorites: each user has a private subcollection under their profile.
    // Only the owner can read/write their own favorites.
    match /users/{uid}/favorites/{slug} {
      allow read, list, write: if request.auth != null && request.auth.uid == uid;
    }

    // Folders: private per-user folders for organizing sets (Quizlet-style).
    match /users/{uid}/folders/{folderId} {
      allow read, list, write: if request.auth != null && request.auth.uid == uid;
    }

    // Question stats: per-user, per-question stats for Zona Débil + Repaso Inteligente (Leitner).
    // Only the owner can read/write. Doc id = `${setId}__${questionId}`.
    match /users/{uid}/questionStats/{statId} {
      allow read, list, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Stripe / Invertase Extension ──────────────────────────────────────────

    // Products and prices: public read (PricingPage displays them), written by Extension only.
    match /products/{productId} {
      allow read: if true;
      allow write: if false;

      match /prices/{priceId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Customer records: each user sees only their own. Only Cloud Functions write.
    match /customers/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;

      // Users write here to trigger the Extension's createCheckoutSession CF.
      match /checkout_sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Subscription state written by Extension webhook handler CF only — tamper-proof.
      match /subscriptions/{subId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Payment records written by Extension — read-only for the owner.
      match /payments/{paymentId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }
  }
}
