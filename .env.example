# Variables de Entorno — Ejemplo
# Copiar este archivo a .env y completar los valores reales
# NUNCA commitear el archivo .env

# =============================================================================
# APLICACIÓN
# =============================================================================
APP_NAME=base-project
APP_ENV=development          # development | staging | production
APP_PORT=3000
APP_LOG_LEVEL=info           # debug | info | warn | error

# =============================================================================
# MCP — Model Context Protocol
# =============================================================================

# Caveman — Debug logging
# Obtener en: [URL de configuración de Caveman]
CAVEMAN_ENABLED=true
CAVEMAN_LOG_LEVEL=debug

# Claudemem — Memoria persistente cross-session
# Obtener en: [URL de configuración de Claudemem]
CLAUDEMEM_ENABLED=true
CLAUDEMEM_STORAGE_PATH=./memory

# Engram — Knowledge graph semántico
# Obtener en: [URL de configuración de Engram]
ENGRAM_ENABLED=true
ENGRAM_STORAGE_PATH=./memory/knowledge

# Autoskills — Auto-ejecución de skills
AUTOSKILLS_ENABLED=true
AUTOSKILLS_SKILLS_PATH=./.claude/skills

# =============================================================================
# MCP — Herramientas de Investigación y Seguridad
# =============================================================================

# Tavily — Búsqueda web profunda para Claude (research, CVEs, docs)
# Obtener en: https://tavily.com → API Keys
TAVILY_API_KEY=tvly-your-key-here

# Semgrep — Escaneo de vulnerabilidades de seguridad
# Obtener en: https://semgrep.dev → Settings → Tokens
SEMGREP_APP_TOKEN=your-semgrep-token-here

# =============================================================================
# BASE DE DATOS (si aplica)
# =============================================================================
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mydb
# DB_USER=myuser
# DB_PASSWORD=change_me_in_env

# =============================================================================
# SEGURIDAD
# =============================================================================
# SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
# JWT_EXPIRY=3600

# =============================================================================
# SERVICIOS EXTERNOS (si aplica)
# =============================================================================
# EXTERNAL_API_URL=https://api.example.com
# EXTERNAL_API_KEY=change_me
