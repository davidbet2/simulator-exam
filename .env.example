# Variables de Entorno — Ejemplo
# Copiar este archivo a .env y completar los valores reales
# NUNCA commitear el archivo .env

# =============================================================================
# APLICACIÓN
# =============================================================================
APP_NAME=base-project
APP_ENV=development          # development | staging | production
APP_PORT=3000
APP_LOG_LEVEL=info           # debug | info | warn | error

# =============================================================================
# MCP — Model Context Protocol
# =============================================================================

# Caveman — Debug logging
# Obtener en: [URL de configuración de Caveman]
CAVEMAN_ENABLED=true
CAVEMAN_LOG_LEVEL=debug

# Claudemem — Memoria persistente cross-session
# Obtener en: [URL de configuración de Claudemem]
CLAUDEMEM_ENABLED=true
CLAUDEMEM_STORAGE_PATH=./memory

# Engram — Knowledge graph semántico
# Obtener en: [URL de configuración de Engram]
ENGRAM_ENABLED=true
ENGRAM_STORAGE_PATH=./memory/knowledge

# Autoskills — Auto-ejecución de skills
AUTOSKILLS_ENABLED=true
AUTOSKILLS_SKILLS_PATH=./.claude/skills

# =============================================================================
# MCP — Herramientas de Investigación y Seguridad
# =============================================================================

# Tavily — Búsqueda web profunda para Claude (research, CVEs, docs)
# Obtener en: https://tavily.com → API Keys
TAVILY_API_KEY=tvly-your-key-here

# Semgrep — Escaneo de vulnerabilidades de seguridad
# Obtener en: https://semgrep.dev → Settings → Tokens
SEMGREP_APP_TOKEN=your-semgrep-token-here

# =============================================================================
# BASE DE DATOS (si aplica)
# =============================================================================
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mydb
# DB_USER=myuser
# DB_PASSWORD=change_me_in_env

# =============================================================================
# FIREBASE (Vite — prefijo VITE_ obligatorio para exponer al cliente)
# =============================================================================
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123:web:abc123

# =============================================================================
# GOOGLE ANALYTICS 4
# =============================================================================
# Obtener en: https://analytics.google.com → Admin → Data Streams → Measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# CLOUDFLARE TURNSTILE
# =============================================================================
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
# URL del Cloud Function que verifica el token Turnstile server-side
VITE_TURNSTILE_VERIFY_URL=https://us-central1-your-project.cloudfunctions.net/verifyTurnstileToken

# =============================================================================
# SEGURIDAD
# =============================================================================
# SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
# JWT_EXPIRY=3600

# =============================================================================
# CAPTCHA / SEGURIDAD FORMULARIOS
# =============================================================================
# Cloudflare Turnstile — widget visible en Login y Register
# Obtener en: https://dash.cloudflare.com → Turnstile → Add site
# (La clave SECRETA va en Firebase App Check — NUNCA en el cliente)
VITE_TURNSTILE_SITE_KEY=0x000000000000000000000000       # reemplazar con tu site key

# Google reCAPTCHA v3 — Firebase App Check (protección server-side)
# Obtener en: https://www.google.com/recaptcha/admin/create (tipo v3)
# Luego registrar en Firebase Console → App Check → Registrar app
# (Solo la SITE KEY va aquí — la SECRET KEY va en Firebase Console)
VITE_RECAPTCHA_SITE_KEY=6Lc_your_recaptcha_v3_site_key_here

# =============================================================================
# SERVICIOS EXTERNOS (si aplica)
# =============================================================================
# EXTERNAL_API_URL=https://api.example.com

# =============================================================================
# STRIPE — PAGOS Y SUSCRIPCIONES
# =============================================================================
# Publishable key (SEGURA para el cliente — no es la secret key)
# Obtener en: https://dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Price ID del plan Pro — Stripe Dashboard → Products → CertZen Pro → precio
VITE_STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# NOTA: La STRIPE_SECRET_KEY NUNCA va aquí.
# Va en la configuración de la Firebase Extension (Cloud Secret Manager).
# EXTERNAL_API_KEY=change_me
