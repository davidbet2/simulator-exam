{
  "name": "simulator-exam",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:critical": "eslint src/ --rule '{\"react/jsx-no-undef\":\"error\"}' --max-warnings 0",
    "preview": "vite preview",
    "seed": "node scripts/seed.mjs",
    "seed:official-sets": "node scripts/seed-official-sets.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "deploy": "npm run lint:critical && npm run build && firebase deploy --only \"hosting,firestore\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@hookform/resolvers": "^5.2.2",
    "@invertase/firestore-stripe-payments": "^0.0.8",
    "@lingui/core": "~5.9.5",
    "@lingui/react": "~5.9.5",
    "@lottiefiles/dotlottie-react": "^0.19.0",
    "@marsidev/react-turnstile": "^1.5.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.8.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.13.2",
    "react-scroll-parallax": "^3.5.0",
    "read-excel-file": "^8.0.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@lingui/babel-plugin-lingui-macro": "~5.9.5",
    "@lingui/cli": "~5.9.5",
    "@lingui/vite-plugin": "~5.9.5",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "babel-plugin-macros": "~3.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.2",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint --max-warnings 0 --rule '{\"react/jsx-no-undef\":\"error\"}'"
    ]
  }
}
