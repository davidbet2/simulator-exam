{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "mcpServers": {
    "caveman": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-caveman"
      ],
      "env": {
        "CAVEMAN_LOG_DIR": "$CLAUDE_PROJECT_DIR/memory/sessions",
        "CAVEMAN_LOG_LEVEL": "debug"
      }
    },
    "claudemem": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-claudemem",
        "--storage",
        "$CLAUDE_PROJECT_DIR/memory"
      ],
      "env": {
        "CLAUDEMEM_NAMESPACE": "base-project"
      }
    },
    "engram": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-engram"
      ],
      "env": {
        "ENGRAM_STORAGE_PATH": "$CLAUDE_PROJECT_DIR/memory/knowledge",
        "ENGRAM_NAMESPACE": "base-project"
      }
    },
    "autoskills": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-autoskills",
        "--skills-dir",
        "$CLAUDE_PROJECT_DIR/.claude/skills"
      ]
    },

    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },

    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },

    "semgrep": {
      "command": "npx",
      "args": ["-y", "@semgrep/mcp"],
      "env": {
        "SEMGREP_APP_TOKEN": "${SEMGREP_APP_TOKEN}"
      }
    },

    "preflight": {
      "command": "npx",
      "args": ["-y", "@preflight-dev/preflight-mcp"]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start/inject-context.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-bash.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/gsd-session-state.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/user-prompt/enrich-prompt.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-tool-use/security-check.py\""
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-tool-use/web-security-check.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-tool-use/validate-input.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-read-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-workflow-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-bash.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/gsd-validate-commit.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use/log-activity.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use/update-memory.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "asyncRewake": true,
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use/quality-check.py\""
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-bash.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/gsd-phase-boundary.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use/error-enricher.py\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-compact/save-context.py\""
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-compact/restore-context.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop/finalize-session.py\""
          },
          {
            "type": "prompt",
            "prompt": "Evaluates whether Claude has completed the user's request. Context: $ARGUMENTS\n\nCheck if all user-requested tasks are complete and no errors remain unaddressed. Respond with {\"ok\": true} to allow stopping, or {\"ok\": false, \"reason\": \"[list of pending tasks]\"} to continue working. Be generous — only block if something is clearly forgotten.",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-end/cleanup.py\""
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-failure-logger.js\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-python.js\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start/subagent-context.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/subagent-stop-logger.js\""
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/permission-denied-logger.js\""
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "session_start",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/instructions-loaded-logger.js\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(python tools/scripts/*)",
      "Bash(npm run*)",
      "Bash(pip install --dry-run*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Bash(rmdir /s*)",
      "Bash(del /f*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/.aws/credentials)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  },
  "effortLevel": "medium",
  "autoMemoryEnabled": true,
  "language": "spanish",
  "attribution": {
    "commit": "🤖 Generated with Claude Code\n\nCo-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>",
    "pr": "🤖 Generated with Claude Code"
  },
  "cleanupPeriodDays": 30
}
